## .NET / C# gitignore

# Build results
[Dd]ist/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/
.vscode/

# MSTest test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet Packages
*.nupkg
*.snupkg
.nuget/
packages/
!packages/repositories.config

# NuGet v3's project.json files produces more ignoreable files
*.nuget.props
*.nuget.targets

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Rider
.idea/
*.sln.iml

# User-specific files
*.rsuser
*.user
*.userosscache
*.suo
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# Benchmarks
BenchmarkDotNet.Artifacts/

# .NET publish
publish/
PublishProfiles/

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows shortcuts
*.lnk

# JetBrains Rider
*.sln.iml

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# Local settings
appsettings.local.json

# UI Inspector — runtime artifacts
*.tmp
error.log
settings.json
