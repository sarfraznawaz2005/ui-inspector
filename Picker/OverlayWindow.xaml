<Window x:Class="UIInspector.Picker.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Normal">
    <Grid>
        <Image x:Name="FrozenImage" Stretch="Fill" Visibility="Collapsed"/>
        <Rectangle x:Name="DimOverlay" Fill="#60000000" Visibility="Collapsed"/>
        <Canvas x:Name="OverlayCanvas"/>
    </Grid>
</Window>
